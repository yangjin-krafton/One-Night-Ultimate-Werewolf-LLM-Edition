      "url": "/assets/voices/full_moon/ep1/p10/role/sentinel/after/001/voice.m4a"
    },
    {
      "clipId": "full_moon/ep1/p10/role/troublemaker/during/001",
      "speakerId": "troublemaker",
      "backend": "qwen3",
